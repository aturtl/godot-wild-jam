; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="godot wild jam"
run/main_scene="uid://dnjkh64dknekk"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=120
config/icon="res://icon.svg"
config/canvas_textures/default_texture_filter=0

[autoload]

GlobalData="*res://data/global_data.gd"
SESSIONSTATS="*res://data/stats/session_stats.gd"
LevelInfo="*uid://dhat8quhyx1wq"
SceneLoader="*uid://calxotxulqedv"
GlobalAssembly="*uid://b17a3y5apaqkv"

[display]

window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://assembly/": "purple",
"res://attachments/": "red",
"res://battle/": "purple",
"res://chasses/": "red",
"res://docs/": "teal",
"res://levels/": "pink",
"res://sprites/": "orange"
}

[rendering]

textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
